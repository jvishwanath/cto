# ════════════════════════════════════════════════════════════════════
#  CTO — Code/Trace/Origin   ·   environment reference
#  Every os.environ read in src/ is listed here. Required vars are
#  uncommented; optional ones show their DEFAULT after `=`.
#  Copy → .env, fill the secrets, leave the rest unless overriding.
# ════════════════════════════════════════════════════════════════════

# ── LLM gateway (REQUIRED) ──────────────────────────────────────────
# Corp LiteLLM proxy. App talks OpenAI-SDK to this; gateway routes to
# claude/gpt/gemini per MODELS in config.py.            [config.py:6-7]
LITELLM_URL=https://your-litellm-gateway.example.com
LITELLM_API_KEY=sk-...

# ── Backing services ────────────────────────────────────────────────
# Laptop dev: localhost. EC2/docker: compose overrides these to the
# in-network service hostnames — leave as-is.           [config.py:8-9]
# QDRANT_URL=http://localhost:6333
# POSTGRES_DSN=postgresql://rag:rag@localhost:5432/rag

# ── Data locations ──────────────────────────────────────────────────
# All default to <project>/data/...; override only when mounting
# elsewhere.                      [config.py:11, docs.py:24, confluence.py:45]
# REPOS_DIR=./data/repos
# DOCS_DIR=./data/docs
# CONFLUENCE_CONFIG=./data/connectors/confluence.yaml

# ── Tracing — Arize Phoenix ─────────────────────────────────────────
# Single-container OTel collector + UI on :6006.        [config.py:16-18]
# PHOENIX_ENABLED=true
# PHOENIX_HOST=http://localhost:6006
# PHOENIX_PROJECT=cto

# ── Confluence connector ────────────────────────────────────────────
# DC Personal Access Token (Bearer). Spaces listed in
# data/connectors/confluence.yaml; values there may use ${THESE_VARS}.
CONFLUENCE_TOKEN=
# CONFLUENCE_USER=                 # Cloud only — Basic auth email
# CONFLUENCE_ENABLED=true          # false → scheduler thread not started
                                   #          [app.py:30, scheduler.py:111]

# ── JIRA on-demand tools ────────────────────────────────────────────
# DC PAT (Bearer). Tools no-op gracefully when unset.   [config.py:22-25]
JIRA_TOKEN=
# JIRA_BASE_URL=https://jira.example.com
# JIRA_USER=                       # Cloud only — Basic auth email
# JIRA_VERIFY_SSL=true

# ── Web search ──────────────────────────────────────────────────────
# Optional. Powers the `web_search` tool.                [config.py:10]
TAVILY_API_KEY=

# ── Agent behaviour ─────────────────────────────────────────────────
# Hard cap on ReAct loop iterations.                     [config.py:13]
# AGENT_MAX_ITER=8
# Use langgraph.prebuilt create_react_agent instead of hand-rolled
# loop (parity testing only).                            [graph.py:95]
# AGENT_PREBUILT=false

# ── Graph feature flags ─────────────────────────────────────────────
# Each toggles a node/edge in the StateGraph build. All 128 combos
# compile; turn off to isolate behaviour.                [graph.py:58-64]
# ENABLE_GUARDS=true               # input_guard / output_guard
# ENABLE_MEMORIES=true             # load_memories / save_memories (Store)
# ENABLE_QUERY_ANALYSIS=true       # LLM intent + repo_scope extraction
# ENABLE_CLARIFY=true              # interrupt() human-in-the-loop
# ENABLE_RESEARCH=true             # deep_research subgraph (Send fan-out)
# ENABLE_SUMMARIZE=true            # rolling history compression
# ENABLE_EVALUATOR=true            # CRAG retrieval grade + LLM-judge retry≤2

# ── Server / lifespan ───────────────────────────────────────────────
#                                                        [app.py:29-30,92]
# WATCHER_ENABLED=true             # auto-reindex on data/{repos,docs} change
# UI_ENABLED=true                  # mount Gradio at /ui (CLI sets false)

# ── Auth (Phase 6) ──────────────────────────────────────────────────
# All disabled when unset → local dev stays open.       [api/auth.py]
#
# Server: comma-separated bearer keys accepted on /query /sources
# /sessions. Generate with:  python -c "import secrets;print(secrets.token_urlsafe(32))"
# CTO_API_KEYS=key-for-cli,key-for-ci
#
# Server: trust X-Forwarded-User from a fronting oauth2-proxy / ALB
# (compose --profile oidc). When true, that header IS the user_id.
# CTO_TRUST_FORWARDED_USER=false
#
# Server: Gradio /ui login form. Skip when behind oauth2-proxy.
# CTO_UI_USER=admin
# CTO_UI_PASSWORD=
#
# Client: bearer key the remote CLI sends.               [cli.py]
# CTO_API_KEY=
#
# oauth2-proxy (compose --profile oidc) — fill from your IdP app:
# OIDC_ISSUER_URL=https://<okta-tenant>.okta.com/oauth2/default
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_EMAIL_DOMAINS=example.com
# OIDC_REDIRECT_URL=http://<ec2>:8080/oauth2/callback
# OAUTH2_COOKIE_SECRET=   # python -c "import secrets;print(secrets.token_urlsafe(32))"

# ── Image attachments / OCR (Phase 6+) ─────────────────────────────
# UI 📎 attach reads an image into the query. OCR fast-path (local
# Tesseract) → vision-model fallback (via gateway, no extra deps).
# OCR needs:  pip install '.[ocr]'  +  the tesseract binary
#   macOS: brew install tesseract   ·   RHEL: dnf install tesseract
# OCR_ENABLED=true              # false → always use vision
# VISION_FALLBACK=true          # false → OCR only (no vision-model call)
# OCR_MIN_CHARS=24              # below this, escalate OCR→vision

# ── Remote CLI ──────────────────────────────────────────────────────
# When set, `cto` is a thin SSE client of this server — no local
# torch/qdrant/postgres needed.                          [cli.py:684]
# CTO_REMOTE=http://<ec2-host>:8000

# ── Containerized deployment (see docs/DEPLOY.md) ───────────────────
# Corp root CA to bake into the app image at build time
# (needed when behind a TLS-inspecting proxy).
# CA_CERT=ops/corp-root-ca.crt
# Strip these comma-separated prefixes from repo names when
# deriving logical service names ("acme-billing" → "billing").
# SERVICE_NAME_PREFIXES=acme-,svc-
# Already set inside Dockerfile/compose; only set here if running the
# server directly on a host that needs them:
# HF_HOME=./hf-cache
# SENTENCE_TRANSFORMERS_HOME=./hf-cache/sentence-transformers
# REQUESTS_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt
# SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt
